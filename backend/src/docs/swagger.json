    "/api/v1/loans/{id}": {
      "get": {
        "summary": "Obtener un préstamo por ID",
        "tags": [
          "Préstamos"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Detalles del préstamo"
          },
          "401": {
            "description": "No autorizado: Token faltante o inválido"
          },
          "404": {
            "description": "Préstamo no encontrado"
          }
        }
      },
      "put": {
        "summary": "Actualizar un préstamo",
        "description": "Modifica los datos de un préstamo existente. No es necesario enviar todos los campos, solo los que se desean cambiar.",
        "tags": [
          "Préstamos"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "ID del préstamo a actualizar",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "partnerId": {
                    "type": "integer",
                    "example": 500
                  },
                  "loanType": {
                    "type": "integer",
                    "example": 1
                  },
                  "retiredDate": {
                    "type": "string",
                    "format": "date",
                    "example": "2026-03-25"
                  },
                  "expectedDate": {
                    "type": "string",
                    "format": "date",
                    "example": "2026-03-30"
                  },
                  "withdrawalTime": {
                    "type": "string",
                    "example": "14:30"
                  },
                  "employeeId": {
                    "type": "integer",
                    "example": 5
                  },
                  "name": {
                    "type": "string",
                    "example": "Juan Pérez"
                  },
                  "dni": {
                    "type": "string",
                    "example": "35123456"
                  },
                  "legacyLoanId": {
                    "type": "integer",
                    "example": 1024
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Préstamo actualizado exitosamente"
          },
          "400": {
            "description": "Error en la validación de los datos"
          },
          "401": {
            "description": "No autorizado: Token faltante o inválido"
          },
          "404": {
            "description": "Préstamo no encontrado"
          }
        }
      },
      "delete": {
        "summary": "Eliminar un préstamo",
        "tags": [
          "Préstamos"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Préstamo eliminado"
          },
          "401": {
            "description": "No autorizado: Token faltante o inválido"
          }
        }
      }
    },
    "/api/v1/loan-books": {
      "get": {
        "summary": "Listar todos los libros en préstamo",
        "tags": [
          "Préstamos - Libros"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Lista obtenida correctamente"
          },
          "401": {
            "description": "No autorizado: Token faltante o inválido"
          }
        }
      },
      "post": {
        "summary": "Asociar un libro a un préstamo",
        "tags": [
          "Préstamos - Libros"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "loanId",
                  "bookCode"
                ],
                "properties": {
                  "BookId": {
                    "type": "integer",
                    "example": 101
                  },
                  "loanId": {
                    "type": "integer",
                    "example": 50
                  },
                  "bookCode": {
                    "type": "string",
                    "example": "740.12-B"
                  },
                  "expectedDate": {
                    "type": "string",
                    "format": "date",
                    "example": "2026-04-10"
                  },
                  "returnedDate": {
                    "type": "string",
                    "format": "date",
                    "example": null
                  },
                  "reneweAmount": {
                    "type": "integer",
                    "example": 0
                  },
                  "returned": {
                    "type": "boolean",
                    "example": false
                  },
                  "copy": {
                    "type": "integer",
                    "example": 1
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Libro asociado exitosamente"
          },
          "400": {
            "description": "Error de validación"
          },
          "401": {
            "description": "No autorizado"
          }
        }
      }
    },
