  "paths": {
    "/api/v1/users": {
      "get": {
        "summary": "Listado de Usuarios",
        "description": "Obtener listado de todos los usuarios existentes",
        "tags": [
          "Usuarios"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "401": {
            "description": "No autorizado"
          }
        }
      }
    },
    "/api/v1/users/register": {
      "post": {
        "summary": "Registrar un usuario",
        "description": "Crear un nuevo usuario",
        "tags": [
          "Usuarios"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "username",
                  "email",
                  "password"
                ],
                "properties": {
                  "fullName": {
                    "type": "string",
                    "example": "juan_perez"
                  },
                  "email": {
                    "type": "string",
                    "example": "juan@rivadavia.edu.ar"
                  },
                  "password": {
                    "type": "string",
                    "example": "password123"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Usuario creado exitosamente"
          },
          "400": {
            "description": "Datos incompletos o inválidos (Bad Request)"
          },
          "401": {
            "description": "No autorizado"
          },
          "409": {
            "description": "Conflicto: El usuario o email ya existe"
          }
        }
      }
    },
    "/api/v1/users/login": {
      "post": {
        "summary": "Ingresar sesion con un usuario",
        "description": "Iniciar sesion con un usuario existente",
        "tags": [
          "Usuarios"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "email",
                  "password"
                ],
                "properties": {
                  "email": {
                    "type": "string",
                    "example": "juan@rivadavia.edu.ar"
                  },
                  "password": {
                    "type": "string",
                    "example": "password123"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "El usuario se logueó exitosamente"
          },
          "400": {
            "description": "Datos incompletos o inválidos (Bad Request)"
          },
          "401": {
            "description": "No autorizado"
          },
          "409": {
            "description": "Conflicto: El usuario o email no existe"
          }
        }
      }
    },
    "/api/v1/users/{id}": {
      "get": {
        "summary": "Obtener usuario",
