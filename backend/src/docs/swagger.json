{
  "openapi": "3.0.0",
  "info": {
    "title": "PPSLibrary API - Biblioteca Bernardino Rivadavia",
    "version": "1.0.0",
    "description": "Documentación estática de la API"
  },
  "servers": [
    {
      "url": "http://localhost:4000",
      "description": "Servidor Local"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "paths": {
    "/api/v1/loans": {
      "get": {
        "summary": "Listado de préstamos",
        "tags": ["Loans"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "OK" },
          "401": { "description": "No autorizado" }
        }
      }
    }
  }
}