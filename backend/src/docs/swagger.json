            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "401": {
            "description": "No autorizado"
          },
          "404": {
            "description": "Usuario no encontrado"
          }
        }
      },
      "put": {
        "summary": "Actualizar usuario",
        "description": "Actualizar los datos de un usuario filtrado por su ID único",
        "tags": [
          "Usuarios"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "ID númerico de usuario",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string",
                    "example": "juan@rivadavia.edu.ar"
                  },
                  "password": {
                    "type": "string",
                    "example": "password123"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "El usuario se actualizó exitosamente"
          },
          "400": {
            "description": "Datos incompletos o inválidos (Bad Request)"
          },
          "401": {
            "description": "No autorizado"
          }
        }
      },
      "delete": {
        "summary": "Eliminar usuario",
        "description": "Eliminar los datos de un usuario filtrado por su ID único",
        "tags": [
          "Usuarios"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "ID númerico de usuario",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Usuario eliminado correctamente"
          },
          "401": {
            "description": "No autorizado"
          },
          "404": {
            "description": "Usuario no encontrado"
          }
        }
      }
    },
    "/api/v1/loans": {
      "get": {
        "summary": "Obtener todos los préstamos",
        "tags": [
          "Préstamos"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de préstamos obtenida con éxito"
          },
          "401": {
            "description": "No autorizado - Falta Token"
          }
        }
      },
      "post": {
        "summary": "Crear un nuevo préstamo",
        "description": "Registra un nuevo préstamo de libro en el sistema de la Biblioteca.",
        "tags": [
          "Préstamos"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "partnerId",
                  "loanType",
                  "retiredDate",
                  "expectedDate",
                  "employeeId"
                ],
                "properties": {
                  "legacyLoanId": {
                    "type": "integer",
                    "example": 1024,
                    "description": "ID del sistema antiguo (opcional)"
                  },
                  "partnerId": {
                    "type": "integer",
                    "example": 500
                  },
                  "loanType": {
                    "type": "integer",
                    "example": 1
                  },
                  "retiredDate": {
                    "type": "string",
                    "format": "date",
                    "example": "2026-03-25"
                  },
                  "expectedDate": {
                    "type": "string",
                    "format": "date",
                    "example": "2026-03-30"
                  },
                  "withdrawalTime": {
                    "type": "string",
                    "example": "14:30",
                    "description": "Hora del retiro en formato HH:mm"
                  },
                  "employeeId": {
                    "type": "integer",
                    "example": 5
                  },
                  "name": {
                    "type": "string",
                    "example": "Juan Pérez",
                    "description": "Nombre del socio o persona que retira"
                  },
                  "dni": {
                    "type": "string",
                    "example": "35123456",
                    "description": "DNI del socio"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Préstamo creado"
          },
          "401": {
            "description": "No autorizado: Token faltante o inválido"
          },
          "403": {
            "description": "Prohibido - Rol insuficiente"
          }
        }
      }
    },
    "/api/v1/loans/employee-count": {
